    {
      "name": "Wave 17 治理、安全与维护",
      "item": [
        {
          "name": "诊断治理摘要",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"诊断请求成功\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test(\"包含迁移状态\", function () {",
                  "  pm.expect(json.migration).to.have.property(\"current_revision\");",
                  "  pm.expect(json.migration).to.have.property(\"head_revision\");",
                  "  pm.expect(json.migration).to.have.property(\"has_pending_migrations\");",
                  "});",
                  "pm.test(\"包含 SSH 主机密钥策略\", function () {",
                  "  pm.expect(json.ssh_host_key).to.have.property(\"policy\");",
                  "  pm.expect(json.ssh_host_key).to.have.property(\"known_hosts_configured\");",
                  "});",
                  "pm.test(\"包含认证有效期和数据库状态\", function () {",
                  "  pm.expect(json.auth_lifetime.access_expire_minutes).to.be.a(\"number\");",
                  "  pm.expect(json.database_status.summary).to.be.a(\"string\");",
                  "});",
                  "pm.test(\"不返回敏感字段\", function () {",
                  "  const body = JSON.stringify(json).toLowerCase();",
                  "  pm.expect(body).to.not.include(\"password\");",
                  "  pm.expect(body).to.not.include(\"token\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/diagnostics/config",
            "description": "验证 Wave 17 迁移状态、SSH 主机密钥策略、认证有效期和数据库状态摘要。"
          },
