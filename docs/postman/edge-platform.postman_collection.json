    {
      "name": "批量 SSH 任务",
      "item": [
        {
          "name": "创建演练任务",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"任务创建成功\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set(\"update_task_id\", json.id);",
