{
  "info": {
    "name": "Edge Platform API",
    "description": "远程终端平台 API 验收集合。先运行“登录”，Tests 脚本会自动保存 access_token 和 refresh_token；后续接口继承集合级 Bearer Token。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1",
      "type": "string"
    },
    {
      "key": "username",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "password",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "project_id",
      "value": "frps-import",
      "type": "string"
    },
    {
      "key": "ssh_command",
      "value": "hostname",
      "type": "string"
    },
    {
      "key": "update_task_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "device_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "new_device_project_id",
      "value": "frps-import",
      "type": "string"
    },
    {
      "key": "new_device_location",
      "value": "frps",
      "type": "string"
    },
    {
      "key": "group_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "group_name",
      "value": "Postman 分组",
      "type": "string"
    },
    {
      "key": "password_new",
      "value": "change-me-after-test",
      "type": "string"
    },
    {
      "key": "log_action",
      "value": "device.create",
      "type": "string"
    },
    {
      "key": "log_target_type",
      "value": "device",
      "type": "string"
    },
    {
      "key": "log_status",
      "value": "success",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "最小回归",
      "item": [
        {
          "name": "健康检查",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/health"
          },
          "response": []
        },
        {
          "name": "登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"登录成功\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set(\"access_token\", json.access_token);",
                  "  pm.environment.set(\"access_token\", json.access_token);",
                  "}",
                  "if (json.refresh_token) {",
                  "  pm.collectionVariables.set(\"refresh_token\", json.refresh_token);",
                  "  pm.environment.set(\"refresh_token\", json.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/auth/login"
          },
          "response": []
        },
        {
          "name": "刷新 Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"刷新成功\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set(\"access_token\", json.access_token);",
                  "  pm.environment.set(\"access_token\", json.access_token);",
                  "}",
                  "if (json.refresh_token) {",
                  "  pm.collectionVariables.set(\"refresh_token\", json.refresh_token);",
                  "  pm.environment.set(\"refresh_token\", json.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/auth/refresh"
          },
          "response": []
        },
        {
          "name": "当前用户",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/auth/me"
          },
          "response": []
        },
        {
          "name": "设备列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/devices"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"设备列表请求成功\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.items && json.items.length > 0) {",
                  "  pm.collectionVariables.set(\"device_id\", json.items[0].id);",
                  "  pm.environment.set(\"device_id\", json.items[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "诊断配置",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/diagnostics/config"
          },
          "response": []
        },
        {
          "name": "frps 预览",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dashboard_url\": \"124.70.177.226:7500\",\n  \"username\": \"admin\",\n  \"password\": \"admin\",\n  \"ssh_port_start\": 12001,\n  \"ssh_port_end\": 17000,\n  \"vnc_port_start\": 17001,\n  \"vnc_port_end\": 22000,\n  \"project_id\": \"frps-import\",\n  \"location\": \"frps\",\n  \"overwrite_project_location\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/frps/discover"
          },
          "response": []
        },
        {
          "name": "监控概览",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/monitoring/overview"
          },
          "response": []
        },
        {
          "name": "日志列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/logs"
          },
          "response": []
        }
      ]
    },
    {
      "name": "批量 SSH 任务",
      "item": [
        {
          "name": "创建演练任务",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"任务创建成功\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set(\"update_task_id\", json.id);",
                  "  pm.environment.set(\"update_task_id\", json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman 演练任务\",\n  \"task_type\": \"command\",\n  \"command\": \"{{ssh_command}}\",\n  \"target_filter\": {\n    \"project_id\": \"{{project_id}}\"\n  },\n  \"execution_mode\": \"dry_run\",\n  \"failure_strategy\": \"continue\",\n  \"concurrency_limit\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/update-tasks"
          },
          "response": []
        },
        {
          "name": "创建真实 SSH 任务",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"任务创建成功\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set(\"update_task_id\", json.id);",
                  "  pm.environment.set(\"update_task_id\", json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman 真实 SSH 任务\",\n  \"task_type\": \"command\",\n  \"command\": \"{{ssh_command}}\",\n  \"target_filter\": {\n    \"project_id\": \"{{project_id}}\"\n  },\n  \"execution_mode\": \"ssh_command\",\n  \"failure_strategy\": \"continue\",\n  \"concurrency_limit\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/update-tasks"
          },
          "response": []
        },
        {
          "name": "执行当前更新任务",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"任务执行请求成功\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"任务返回设备结果\", function () {",
                  "  pm.expect(json.devices).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/update-tasks/{{update_task_id}}/execute"
          },
          "response": []
        },
        {
          "name": "查询当前更新任务详情",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/update-tasks/{{update_task_id}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Wave 11 运维增强",
      "item": [
        {
          "name": "诊断安全摘要",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/diagnostics/config"
          },
          "response": []
        },
        {
          "name": "刷新设备状态",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/devices/{{device_id}}/status"
          },
          "response": []
        },
        {
          "name": "编辑设备基础信息",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{new_device_project_id}}\",\n  \"location\": \"{{new_device_location}}\",\n  \"ssh_user\": \"ztl\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/devices/{{device_id}}"
          },
          "response": []
        },
        {
          "name": "取消当前更新任务",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/update-tasks/{{update_task_id}}/cancel"
          },
          "response": []
        },
        {
          "name": "删除设备（谨慎执行）",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/devices/{{device_id}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Wave 12 运维闭环",
      "item": [
        {
          "name": "修改管理员密码（谨慎执行）",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"{{password}}\",\n  \"new_password\": \"{{password_new}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/auth/password"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"密码修改请求成功\", function () {",
                  "  pm.expect([204, 400, 401, 422]).to.include(pm.response.code);",
                  "});",
                  "pm.test(\"如返回 204，请手动把 password 变量改为 password_new 后重新登录\", function () {",
                  "  pm.expect(true).to.equal(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "创建分组",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{group_name}}\",\n  \"description\": \"Postman Wave 12 分组\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/groups"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"分组创建成功或名称已存在\", function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"group_id\", json.id);",
                  "  pm.environment.set(\"group_id\", json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "分组列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/groups"
          },
          "response": []
        },
        {
          "name": "编辑分组",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Postman Wave 12 分组已更新\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/groups/{{group_id}}"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"分组编辑成功\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "删除分组（谨慎执行）",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/groups/{{group_id}}"
          },
          "response": []
        },
        {
          "name": "日志筛选",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/logs?offset=0&limit=50&action={{log_action}}&target_type={{log_target_type}}&status={{log_status}}"
          },
          "response": []
        },
        {
          "name": "导出日志 CSV",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/logs/export?action={{log_action}}&target_type={{log_target_type}}&status={{log_status}}"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"CSV 导出请求成功\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"返回 CSV\", function () { pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"text/csv\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "设备同步配置",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/devices/{{device_id}}/sync-config"
          },
          "response": []
        },
        {
          "name": "系统诊断配置",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/diagnostics/config"
          },
          "response": []
        }
      ]
    }
  ]
}
